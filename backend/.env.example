# ─────────────────────────────────────────────
# FlowGram Backend — Environment Configuration
# Copy this to .env and fill in your values
# ─────────────────────────────────────────────

NODE_ENV=production
PORT=5000

# ── Database (PostgreSQL) ──
DB_HOST=localhost
DB_PORT=5432
DB_NAME=flowgram
DB_USER=flowgram_user
DB_PASSWORD=your_strong_password_here
DB_SSL=true
DATABASE_URL=postgresql://flowgram_user:your_strong_password_here@localhost:5432/flowgram

# ── Redis ──
REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=your_redis_password

# ── JWT ──
JWT_SECRET=your_super_secret_jwt_key_min_32_chars_here
JWT_REFRESH_SECRET=your_refresh_secret_key_min_32_chars
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# ── App URLs ──
FRONTEND_URL=https://yourdomain.com
API_URL=https://api.yourdomain.com
APP_NAME=FlowGram

# ── Razorpay ──
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret

# ── Cashfree ──
CASHFREE_APP_ID=your_cashfree_app_id
CASHFREE_SECRET_KEY=your_cashfree_secret
CASHFREE_ENV=PRODUCTION

# ── Email (SMTP) ──
SMTP_HOST=smtp.sendgrid.net
SMTP_PORT=587
SMTP_USER=apikey
SMTP_PASS=your_sendgrid_api_key
EMAIL_FROM=noreply@yourdomain.com
EMAIL_FROM_NAME=FlowGram

# ── Instagram / Meta ──
META_APP_ID=your_meta_app_id
META_APP_SECRET=your_meta_app_secret
META_WEBHOOK_VERIFY_TOKEN=your_random_verify_token

# ── Security ──
COOKIE_SECRET=your_cookie_secret_here
ENCRYPTION_KEY=32_char_encryption_key_here_abcd
BCRYPT_ROUNDS=12

# ── Rate Limiting ──
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX=100

# ── Plans (DMs/month) ──
FREE_DM_LIMIT=1000
PRO_DM_LIMIT=10000
BUSINESS_DM_LIMIT=999999
