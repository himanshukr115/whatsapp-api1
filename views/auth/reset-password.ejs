<!-- views/auth/reset-password.ejs -->
<h2 class="auth-title">Reset password</h2>
<p class="auth-subtitle">Choose a strong new password</p>

<% if (error && error.length) { %>
<div class="alert alert-error"><% error.forEach(m => { %><%= m %><% }) %></div>
<% } %>

<form action="/auth/reset-password/<%= token %>" method="POST" class="auth-form">
  <div class="form-group">
    <label class="form-label">New Password</label>
    <input type="password" name="password" class="form-input" placeholder="Min 8 characters" required autofocus>
  </div>
  <button type="submit" class="btn-auth">Reset Password</button>
</form>
