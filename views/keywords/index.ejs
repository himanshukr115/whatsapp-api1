<!-- views/keywords/index.ejs -->
<div class="page-header">
  <div>
    <h2>Keyword Triggers</h2>
    <p class="page-sub">Automate responses when specific words are detected</p>
  </div>
  <button class="btn-primary" onclick="document.getElementById('addKwModal').style.display='flex'">+ Add Keyword</button>
</div>

<div class="card">
  <% if (keywords.length === 0) { %>
  <div class="empty-state">
    <p>No keywords yet. Add your first keyword trigger to start automating.</p>
  </div>
  <% } else { %>
  <table class="data-table">
    <thead><tr>
      <th>Keyword</th><th>Match Type</th><th>Trigger On</th><th>Linked Flow</th><th>Triggers</th><th>Status</th><th>Actions</th>
    </tr></thead>
    <tbody>
      <% keywords.forEach(kw => { %>
      <tr>
        <td><span class="kw-pill"><%= kw.keyword %></span></td>
        <td><%= kw.match_type %></td>
        <td><%= kw.trigger_on %></td>
        <td><%= kw.flow_name || '—' %></td>
        <td><%= kw.trigger_count %></td>
        <td>
          <label class="toggle">
            <input type="checkbox" class="toggle-input" data-id="<%= kw.id %>" <%= kw.is_active ? 'checked' : '' %> onchange="toggleKw(this)">
            <span class="toggle-track"></span>
          </label>
        </td>
        <td>
          <form action="/keywords/<%= kw.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete keyword?')">
            <button class="btn-sm-danger">Delete</button>
          </form>
        </td>
      </tr>
      <% }) %>
    </tbody>
  </table>
  <% } %>
</div>

<!-- Add Keyword Modal -->
<div id="addKwModal" class="modal-backdrop" style="display:none" onclick="if(event.target===this)this.style.display='none'">
  <div class="modal">
    <div class="modal-header">
      <h3>Add Keyword Trigger</h3>
      <button class="btn-icon" onclick="document.getElementById('addKwModal').style.display='none'">✕</button>
    </div>
    <form action="/keywords" method="POST">
      <div class="form-group">
        <label class="form-label">Keyword / Phrase *</label>
        <input type="text" name="keyword" class="form-input" placeholder="e.g. price, FREE, how much" required>
      </div>
      <div class="form-row-2">
        <div class="form-group">
          <label class="form-label">Match Type</label>
          <select name="match_type" class="form-select">
            <option value="contains">Contains</option>
            <option value="exact">Exact match</option>
            <option value="starts_with">Starts with</option>
          </select>
        </div>
        <div class="form-group">
          <label class="form-label">Trigger On</label>
          <select name="trigger_on" class="form-select">
            <option value="both">DMs + Comments</option>
            <option value="dm">DMs only</option>
            <option value="comment">Comments only</option>
          </select>
        </div>
      </div>
      <div class="form-group">
        <label class="form-label">Link to Flow</label>
        <select name="flow_id" class="form-select">
          <option value="">— Select flow (optional) —</option>
          <% flows.forEach(f => { %>
          <option value="<%= f.id %>"><%= f.name %></option>
          <% }) %>
        </select>
      </div>
      <div style="display:flex;gap:8px;margin-top:8px">
        <button type="button" class="btn-ghost" onclick="document.getElementById('addKwModal').style.display='none'">Cancel</button>
        <button type="submit" class="btn-primary" style="flex:1">Add Keyword</button>
      </div>
    </form>
  </div>
</div>

<script>
async function toggleKw(checkbox) {
  const id = checkbox.dataset.id;
  try {
    await fetch(`/keywords/${id}/toggle`, { method: 'POST' });
  } catch(e) { checkbox.checked = !checkbox.checked; }
}
</script>
