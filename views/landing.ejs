<!-- views/landing.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>FlowGram — Instagram Automation for Creators</title>
  <link href="https://fonts.googleapis.com/css2?family=Syne:wght@600;700;800&family=DM+Sans:wght@300;400;500&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/app.css">
</head>
<body class="landing-body">

<!-- NAV -->
<nav class="landing-nav">
  <a href="/" class="landing-logo"><span>⚡</span> FlowGram</a>
  <div class="landing-nav-links">
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="/auth/login" class="btn-outline-sm">Login</a>
    <a href="/auth/register" class="btn-primary-sm">Get Started Free</a>
  </div>
</nav>

<!-- HERO -->
<section class="hero">
  <div class="hero-badge">🚀 Trusted by 1000+ Instagram creators</div>
  <h1 class="hero-title">Automate Your Instagram.<br><span class="gradient-text">Grow on Autopilot.</span></h1>
  <p class="hero-subtitle">Send automated DMs, reply to comments, capture leads with keywords — all without lifting a finger. Built for Indian creators and businesses.</p>
  <div class="hero-actions">
    <a href="/auth/register" class="btn-hero-primary">Start Free — No credit card needed</a>
    <a href="#features" class="btn-hero-ghost">See how it works →</a>
  </div>
  <div class="hero-stats">
    <div class="hero-stat"><strong>50K+</strong><span>DMs sent daily</span></div>
    <div class="hero-stat"><strong>1000+</strong><span>Active users</span></div>
    <div class="hero-stat"><strong>4.9★</strong><span>User rating</span></div>
  </div>
</section>

<!-- FEATURES -->
<section id="features" class="features-section">
  <div class="section-label">Features</div>
  <h2 class="section-title">Everything you need to automate Instagram</h2>
  <div class="features-grid">
    <div class="feature-card">
      <div class="feature-icon">⚡</div>
      <h3>Automation Flows</h3>
      <p>Build powerful multi-step flows triggered by DMs, comments, story replies, or keywords. No code required.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🔑</div>
      <h3>Keyword Triggers</h3>
      <p>When someone types "price" or "FREE" in your comments or DMs, instantly start an automation flow.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">💬</div>
      <h3>DM Inbox</h3>
      <p>Manage all your Instagram DMs in one place with quick replies, contact history, and manual overrides.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">📈</div>
      <h3>Analytics</h3>
      <p>Track DMs sent, open rates, flow performance, and conversion metrics with beautiful charts.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🤖</div>
      <h3>AI Smart Replies</h3>
      <p>Let AI craft context-aware responses. Upgrade to Pro and never miss a sales opportunity again.</p>
    </div>
    <div class="feature-card">
      <div class="feature-icon">🛡️</div>
      <h3>Safe & Compliant</h3>
      <p>Built on the official Meta Graph API. Rate limits, quiet hours, and anti-spam protection built in.</p>
    </div>
  </div>
</section>

<!-- PRICING -->
<section id="pricing" class="pricing-section">
  <div class="section-label">Pricing</div>
  <h2 class="section-title">Simple, transparent pricing</h2>
  <p class="section-sub">Start free. Upgrade when you're ready to scale.</p>
  <div class="pricing-grid">
    <div class="pricing-card">
      <div class="plan-name">Free</div>
      <div class="plan-price">₹0<span>/month</span></div>
      <ul class="plan-features">
        <li>✓ 1,000 DMs per month</li>
        <li>✓ 3 active flows</li>
        <li>✓ 1 Instagram account</li>
        <li>✓ Basic analytics</li>
        <li>✓ Email support</li>
      </ul>
      <a href="/auth/register" class="btn-plan-ghost">Get Started Free</a>
    </div>
    <div class="pricing-card pricing-card-featured">
      <div class="plan-badge">Most Popular</div>
      <div class="plan-name">Pro</div>
      <div class="plan-price">₹999<span>/month</span></div>
      <ul class="plan-features">
        <li>✓ 10,000 DMs per month</li>
        <li>✓ Unlimited flows</li>
        <li>✓ 3 Instagram accounts</li>
        <li>✓ Advanced analytics</li>
        <li>✓ AI smart replies</li>
        <li>✓ Priority support</li>
      </ul>
      <a href="/auth/register" class="btn-plan-primary">Start Pro Trial</a>
    </div>
    <div class="pricing-card">
      <div class="plan-name">Business</div>
      <div class="plan-price">₹2,999<span>/month</span></div>
      <ul class="plan-features">
        <li>✓ Unlimited DMs</li>
        <li>✓ Unlimited flows</li>
        <li>✓ 10 Instagram accounts</li>
        <li>✓ Full analytics suite</li>
        <li>✓ API access</li>
        <li>✓ 24/7 dedicated support</li>
      </ul>
      <a href="/auth/register" class="btn-plan-ghost">Contact Sales</a>
    </div>
  </div>
</section>

<!-- CTA -->
<section class="cta-section">
  <h2>Ready to grow on autopilot?</h2>
  <p>Join 1000+ creators already using FlowGram to save hours every week.</p>
  <a href="/auth/register" class="btn-hero-primary">Create Free Account →</a>
</section>

<!-- FOOTER -->
<footer class="landing-footer">
  <div class="footer-logo"><span>⚡</span> FlowGram</div>
  <div class="footer-links">
    <a href="#">Privacy Policy</a>
    <a href="#">Terms of Service</a>
    <a href="#">Contact</a>
  </div>
  <p class="footer-copy">© 2025 FlowGram. Made in India 🇮🇳</p>
</footer>

<script src="/js/app.js"></script>
</body>
</html>
