<nav class="landing-nav">
  <a href="/" class="landing-logo"><span>⚡</span> FlowGram</a>
  <button class="landing-menu-toggle" type="button" aria-label="Toggle menu" onclick="toggleLandingMenu()">☰</button>
  <div class="landing-nav-links" id="landingNavLinks">
    <a href="#features">Features</a>
    <a href="#pricing">Pricing</a>
    <a href="/auth/login" class="btn-outline-sm">Login</a>
    <a href="/auth/register" class="btn-primary-sm">Get Started Free</a>
  </div>
</nav>

<section class="hero">
  <div class="hero-badge">🚀 Trusted by 1000+ Instagram creators</div>
  <h1 class="hero-title">Automate Your Instagram.<br><span class="gradient-text">Grow on Autopilot.</span></h1>
  <p class="hero-subtitle">Send automated DMs, reply to comments, capture leads with keywords — all without lifting a finger. Built for Indian creators and businesses.</p>
  <div class="hero-actions">
    <a href="/auth/register" class="btn-hero-primary">Start Free — No credit card needed</a>
    <a href="#features" class="btn-hero-ghost">See how it works →</a>
  </div>
  <div class="hero-stats">
    <div class="hero-stat"><strong>50K+</strong><span>DMs sent daily</span></div>
    <div class="hero-stat"><strong>1000+</strong><span>Active users</span></div>
    <div class="hero-stat"><strong>4.9★</strong><span>User rating</span></div>
  </div>
</section>

<section id="features" class="features-section">
  <div class="section-label">Features</div>
  <h2 class="section-title">Everything you need to automate Instagram</h2>
  <div class="features-grid">
    <div class="feature-card"><div class="feature-icon">⚡</div><h3>Automation Flows</h3><p>Build powerful multi-step flows triggered by DMs, comments, story replies, or keywords. No code required.</p></div>
    <div class="feature-card"><div class="feature-icon">🔑</div><h3>Keyword Triggers</h3><p>When someone types "price" or "FREE" in your comments or DMs, instantly start an automation flow.</p></div>
    <div class="feature-card"><div class="feature-icon">💬</div><h3>DM Inbox</h3><p>Manage all your Instagram DMs in one place with quick replies, contact history, and manual overrides.</p></div>
    <div class="feature-card"><div class="feature-icon">📈</div><h3>Analytics</h3><p>Track DMs sent, open rates, flow performance, and conversion metrics with beautiful charts.</p></div>
    <div class="feature-card"><div class="feature-icon">🤖</div><h3>AI Smart Replies</h3><p>Let AI craft context-aware responses. Upgrade to Pro and never miss a sales opportunity again.</p></div>
    <div class="feature-card"><div class="feature-icon">🛡️</div><h3>Safe & Compliant</h3><p>Built on the official Meta Graph API. Rate limits, quiet hours, and anti-spam protection built in.</p></div>
  </div>
</section>

<section id="pricing" class="pricing-section">
  <div class="section-label">Pricing</div>
  <h2 class="section-title">Simple, transparent pricing</h2>
  <p class="section-sub">Start free. Upgrade when you're ready to scale.</p>

  <div class="billing-toggle-wrap landing-toggle">
    <span id="landingMonthly" class="billing-toggle-label active">Monthly</span>
    <label class="billing-toggle-switch">
      <input type="checkbox" id="landingCycleToggle" onchange="toggleLandingCycle()">
      <span class="billing-toggle-track"></span>
    </label>
    <span id="landingYearly" class="billing-toggle-label">Yearly <span class="save-badge">Save up to <%= maxDiscount %>%</span></span>
  </div>

  <div class="pricing-grid">
    <% plans.forEach((plan) => { %>
      <div class="pricing-card <%= plan.slug === 'pro' ? 'pricing-card-featured' : '' %>">
        <% if (plan.slug === 'pro') { %><div class="plan-badge">Most Popular</div><% } %>
        <div class="plan-name"><%= plan.name %></div>
        <div class="plan-price plan-price-monthly">₹<%= Math.floor(plan.price_monthly / 100).toLocaleString('en-IN') %><span>/month</span></div>
        <div class="plan-price plan-price-yearly" style="display:none;">
          ₹<%= Math.max(0, Math.floor(plan.price_yearly / 1200)).toLocaleString('en-IN') %><span>/month</span>
          <div class="price-billed-yearly">₹<%= Math.floor(plan.price_yearly / 100).toLocaleString('en-IN') %> billed yearly</div>
        </div>
        <ul class="plan-features">
          <% (plan.features || []).forEach((feature) => { %><li>✓ <%= feature %></li><% }) %>
        </ul>
        <a href="/auth/register" class="<%= plan.slug === 'pro' ? 'btn-plan-primary' : 'btn-plan-ghost' %>">Get Started</a>
      </div>
    <% }) %>
  </div>
</section>

<section class="cta-section">
  <h2>Ready to grow on autopilot?</h2>
  <p>Join 1000+ creators already using FlowGram to save hours every week.</p>
  <a href="/auth/register" class="btn-hero-primary">Create Free Account →</a>
</section>

<footer class="landing-footer">
  <div class="footer-logo"><span>⚡</span> FlowGram</div>
  <div class="footer-links"><a href="#">Privacy Policy</a><a href="#">Terms of Service</a><a href="#">Contact</a></div>
  <p class="footer-copy">© 2026 FlowGram. Made in India 🇮🇳</p>
</footer>

<script>
function toggleLandingMenu() {
  document.getElementById('landingNavLinks').classList.toggle('open');
}
function toggleLandingCycle() {
  const yearly = document.getElementById('landingCycleToggle').checked;
  document.querySelectorAll('.pricing-section .plan-price-monthly').forEach(el => el.style.display = yearly ? 'none' : 'block');
  document.querySelectorAll('.pricing-section .plan-price-yearly').forEach(el => el.style.display = yearly ? 'block' : 'none');
  document.getElementById('landingMonthly').classList.toggle('active', !yearly);
  document.getElementById('landingYearly').classList.toggle('active', yearly);
}
</script>
